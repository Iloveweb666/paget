{
  "name": "paget",
  "version": "0.1.0",
  "private": true,
  "description": "Paget - AI-powered page agent with reflection-before-action",
  "scripts": {
    "dev:ui": "pnpm --filter @paget/ui dev",
    "dev:server": "pnpm --filter @paget/server dev",
    "dev": "pnpm run dev:server & pnpm run dev:ui",
    "build": "pnpm -r run build",
    "build:shared": "pnpm --filter @paget/shared build",
    "build:page-controller": "pnpm --filter @paget/page-controller build",
    "build:ui": "pnpm --filter @paget/ui build",
    "build:server": "pnpm --filter @paget/server build",
    "lint": "eslint packages --ext .ts,.vue",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
}
