{
  "name": "@paget/ui",
  "version": "0.1.3",
  "description": "Paget AI - Page automation agent UI with bookmarklet support",
  "type": "module",
  "main": "dist/iife/paget.bookmarklet.js",
  "files": [
    "dist/iife"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:bookmarklet": "vue-tsc -b && vite build --config vite.iife.config.ts",
    "prepublishOnly": "pnpm build:bookmarklet",
    "preview": "vite preview"
  },
  "keywords": [
    "paget",
    "ai",
    "agent",
    "automation",
    "bookmarklet"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paget-ai/paget.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@paget/page-controller": "workspace:*",
    "@paget/shared": "workspace:*",
    "element-plus": "^2.13.5",
    "marked": "^12.0.0",
    "pinia": "^2.2.0",
    "socket.io-client": "^4.7.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.0",
    "terser": "^5.31.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-css-injected-by-js": "^3.5.0",
    "vue-tsc": "^2.1.0"
  }
}
